---
interface Props {
  slug: string;
  title: string;
  description: string;
  category: string;
  tags: string[];
  readingTime: number;
  publishedDate?: Date;
  lang?: string;
  class?: string;
}

const {
  slug,
  title,
  description,
  category,
  tags,
  readingTime,
  publishedDate,
  lang = 'pt',
  class: className = '',
} = Astro.props;

const href = lang === 'pt' ? `/blog/${slug}` : `/${lang}/blog/${slug}`;

const minReadLabel = lang === 'en' ? 'min read' : lang === 'es' ? 'min de lectura' : 'min de leitura';
const readMoreLabel = lang === 'en' ? 'Read more' : lang === 'es' ? 'Leer más' : 'Ler mais';

// Category color palette
const categoryColors: Record<string, string> = {
  backend: 'from-blue-900/80 to-blue-800/60',
  frontend: 'from-purple-900/80 to-purple-800/60',
  mobile: 'from-green-900/80 to-green-800/60',
  devops: 'from-orange-900/80 to-orange-800/60',
  ia: 'from-pink-900/80 to-pink-800/60',
  ai: 'from-pink-900/80 to-pink-800/60',
  architecture: 'from-indigo-900/80 to-indigo-800/60',
  carreira: 'from-teal-900/80 to-teal-800/60',
  career: 'from-teal-900/80 to-teal-800/60',
};

const categoryGradient = categoryColors[category.toLowerCase()] ?? 'from-navy-light/80 to-navy-dark/60';

const formattedDate = publishedDate
  ? new Intl.DateTimeFormat(lang, { year: 'numeric', month: 'short', day: 'numeric' }).format(publishedDate)
  : null;
---

<a
  href={href}
  class={`blog-card group block w-72 md:w-80 flex-shrink-0 bg-navy-light border border-border rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/5 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-navy ${className}`}
  aria-label={title}
>
  <!-- Colored header by category -->
  <div class={`relative h-32 bg-gradient-to-br ${categoryGradient} overflow-hidden flex flex-col justify-end p-4`}>
    <!-- Category badge -->
    <span class="absolute top-3 left-4 inline-block px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-text-primary bg-white/10 backdrop-blur-sm rounded-full border border-white/20">
      {category}
    </span>

    <!-- Reading time + date in header -->
    <div class="flex items-center gap-3 text-xs text-text-secondary/80">
      <span class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
        </svg>
        {readingTime} {minReadLabel}
      </span>
      {formattedDate && <span>{formattedDate}</span>}
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col gap-3">
    <h3 class="text-text-primary font-semibold text-base leading-snug group-hover:text-accent transition-colors duration-200 line-clamp-2">
      {title}
    </h3>
    <p class="text-text-secondary text-sm leading-relaxed line-clamp-3">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.slice(0, 3).map((tag) => (
        <span class="inline-block px-2 py-0.5 text-xs font-mono text-text-secondary bg-navy-dark/60 rounded border border-border">
          #{tag}
        </span>
      ))}
    </div>

    <!-- Read more link -->
    <span class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-1 group-hover:gap-2 transition-all duration-200">
      {readMoreLabel}
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </span>
  </div>
</a>
