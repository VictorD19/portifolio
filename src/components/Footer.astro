---
import type { Lang } from '../i18n/config';
import { t, getLocalizedPath } from '../i18n/config';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getServicesByLang } from '../data/services';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const currentPath = Astro.url.pathname;

const WA_URL = 'https://wa.me/5549998218294?text=Ol%C3%A1%20Victor%2C%20vi%20seu%20portf%C3%B3lio%20e%20gostaria%20de%20conversar%20sobre%20um%20projeto.';

const navLinks = [
  { key: 'nav.home', href: getLocalizedPath('/', lang) },
  { key: 'nav.projects', href: getLocalizedPath('/projects', lang) },
  { key: 'nav.services', href: getLocalizedPath('/services', lang) },
  { key: 'nav.blog', href: getLocalizedPath('/blog', lang) },
  { key: 'nav.contact', href: getLocalizedPath('/contact', lang) },
];

const servicesList = getServicesByLang(lang);

const year = new Date().getFullYear();
---

<footer class="bg-navy-dark border-t border-border mt-24">
  <!-- Gradient divider top -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>

  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Col 1: Logo, bio, socials -->
      <div class="flex flex-col gap-5">
        <a
          href={getLocalizedPath('/', lang)}
          class="text-text-primary font-bold text-lg hover:text-accent transition-colors"
          aria-label="Victor Bertram – Home"
        >
          Victor.Bertram<span class="text-accent">.</span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed">
          {t(lang, 'footer.bio')}
        </p>

        <!-- Availability badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-accent/10 border border-accent/20 rounded-full w-fit">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse" aria-hidden="true"></span>
          <span class="text-xs text-accent font-medium">{t(lang, 'footer.available')}</span>
        </div>

        <!-- Social icons -->
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/victorbertram"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="text-text-secondary hover:text-text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/victord08"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-text-secondary hover:text-text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <a
            href={WA_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="text-text-secondary hover:text-text-primary transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Navigation -->
      <div class="flex flex-col gap-5">
        <h3 class="text-text-primary font-semibold text-sm uppercase tracking-wider">
          {t(lang, 'footer.navigation')}
        </h3>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-text-secondary text-sm hover:text-accent transition-colors duration-200"
              >
                {t(lang, link.key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div class="flex flex-col gap-5">
        <h3 class="text-text-primary font-semibold text-sm uppercase tracking-wider">
          {t(lang, 'footer.services')}
        </h3>
        <ul class="flex flex-col gap-3">
          {servicesList.map((service) => (
            <li>
              <a
                href={getLocalizedPath(`/services`, lang)}
                class="text-text-secondary text-sm hover:text-accent transition-colors duration-200"
              >
                {service.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Contact -->
      <div class="flex flex-col gap-5">
        <h3 class="text-text-primary font-semibold text-sm uppercase tracking-wider">
          {t(lang, 'footer.contact')}
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href="mailto:bertramvictor8@gmail.com"
              class="flex items-center gap-2 text-text-secondary text-sm hover:text-accent transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
              </svg>
              bertramvictor8@gmail.com
            </a>
          </li>
          <li>
            <span class="flex items-center gap-2 text-text-secondary text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
              </svg>
              Chapecó, SC – Brasil
            </span>
          </li>
          <li>
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-accent text-sm hover:text-accent/80 transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp
            </a>
          </li>
        </ul>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-border">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-secondary text-xs">
        &copy; {year} Victor Bertram. {t(lang, 'footer.rights')}
      </p>
      <LanguageSwitcher currentLang={lang} currentPath={currentPath} />
    </div>
  </div>
</footer>
