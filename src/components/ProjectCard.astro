---
interface Props {
  slug: string;
  title: string;
  description: string;
  tech: string[];
  image?: string;
  badge?: string;
  lang?: string;
  class?: string;
}

const {
  slug,
  title,
  description,
  tech,
  image,
  badge,
  lang = 'pt',
  class: className = '',
} = Astro.props;

const href = lang === 'pt' ? `/projects/${slug}` : `/${lang}/projects/${slug}`;
---

<a
  href={href}
  class={`project-card group block bg-navy-light border border-border rounded-xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg hover:shadow-accent/5 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white ${className}`}
  aria-label={title}
>
  <!-- Image area -->
  <div class="relative h-44 bg-navy-dark overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="flex items-center justify-center h-full">
        <div class="text-5xl opacity-20 select-none">{'</>'}</div>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col gap-3">
    <h3 class="text-text-primary font-semibold text-lg leading-snug group-hover:text-accent transition-colors duration-200 line-clamp-2">
      {title}
    </h3>
    <p class="text-text-secondary text-sm leading-relaxed line-clamp-3">
      {description}
    </p>

    <!-- Tech tags -->
    <div class="flex flex-wrap gap-2 mt-1">
      {tech.slice(0, 4).map((tag) => (
        <span class="inline-block px-2 py-0.5 text-xs font-mono text-accent bg-accent/10 rounded border border-accent/20">
          {tag}
        </span>
      ))}
      {tech.length > 4 && (
        <span class="inline-block px-2 py-0.5 text-xs font-mono text-text-secondary bg-navy-dark/60 rounded border border-border">
          +{tech.length - 4}
        </span>
      )}
    </div>
  </div>
</a>
