---
import type { Lang } from '../../i18n/config';
import { t, getLocalizedPath } from '../../i18n/config';
import ScrollAnimation from '../ScrollAnimation.astro';
import BlogCard from '../BlogCard.astro';
import { getCollection } from 'astro:content';
import { idToSlug, getReadingTime } from '../../lib/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === lang && !data.draft;
});

const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section class="py-24 max-w-6xl mx-auto px-6" aria-labelledby="blog-heading">
    <ScrollAnimation animation="fade-in">
      <div class="flex items-center justify-between mb-12">
        <div class="flex items-center gap-4">
          <span class="text-accent font-mono text-sm">03.</span>
          <h2 id="blog-heading" class="text-3xl md:text-4xl font-bold text-text-primary">
            {t(lang, 'sections.blog')}
          </h2>
          <div class="hidden sm:block flex-1 h-px bg-border max-w-xs" aria-hidden="true"></div>
        </div>
        <a
          href={getLocalizedPath('/blog', lang)}
          class="text-sm text-accent hover:text-accent/80 transition-colors flex items-center gap-1 shrink-0"
        >
          {t(lang, 'sections.view_all_posts')}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </ScrollAnimation>

    <ScrollAnimation animation="fade-in" delay={150}>
      <div class="flex flex-wrap gap-4">
        {posts.map((post) => (
          <div class="w-full sm:w-[calc(50%-8px)] lg:w-[calc(33.333%-11px)]">
            <BlogCard
              slug={idToSlug(post.id)}
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              tags={post.data.tags}
              readingTime={getReadingTime(post.body ?? '')}
              publishedDate={post.data.date}
              lang={lang}
            />
          </div>
        ))}
      </div>
    </ScrollAnimation>
  </section>
)}
