---
import type { Lang } from '../../i18n/config';
import { t, getLocalizedPath } from '../../i18n/config';
import ScrollAnimation from '../ScrollAnimation.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="py-24 bg-navy-dark/40" aria-labelledby="cta-heading">
  <div class="max-w-6xl mx-auto px-6">
    <ScrollAnimation animation="scale-in">
      <div class="text-center max-w-2xl mx-auto">
        <span class="text-accent font-mono text-sm block mb-4">04.</span>
        <h2 id="cta-heading" class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
          {t(lang, 'sections.cta_title')}
        </h2>
        <p class="text-text-secondary text-lg mb-10 leading-relaxed">
          {t(lang, 'sections.cta_text')}
        </p>
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-navy font-semibold rounded-lg hover:bg-accent/90 transition-all duration-200 text-lg"
        >
          {t(lang, 'sections.cta_button')}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </ScrollAnimation>
  </div>
</section>
