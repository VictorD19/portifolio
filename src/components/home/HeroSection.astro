---
import type { Lang } from '../../i18n/config';
import { t, getLocalizedPath } from '../../i18n/config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const WA_URL = 'https://wa.me/5549998218294?text=Ol%C3%A1%20Victor%2C%20vi%20seu%20portf%C3%B3lio%20e%20gostaria%20de%20conversar%20sobre%20um%20projeto.';

const topTechs = [
  // Linguagens
  'JavaScript', 'TypeScript', 'C#',
  // Frameworks
  '.NET', 'Node.js', 'Next.js', 'React',
  // Banco de dados
  'PostgreSQL', 'SQL Server', 'MongoDB',
  // Infra & Cloud
  'AWS', 'Docker', 'CI/CD',
];

const liveProjects = [
  { name: 'SistemaZapChat', url: 'https://sistemaZapChat.com', icon: 'chat' },
  { name: 'SmartVoz', url: 'https://smartvoz.com.br', icon: 'signal' },
  { name: 'DesafiosBíblicos', url: 'https://desafiosbiblicos.com.br', icon: 'trophy' },
];

const headline = {
  pt: 'Desenvolvedor Full Stack com mentalidade de dono: entrega ágil, código limpo e foco em manutenção e evolução.',
  en: 'Full Stack Developer with an ownership mindset: agile delivery, clean code, and focus on maintenance and evolution.',
  es: 'Desarrollador Full Stack con mentalidad de dueño: entrega ágil, código limpio y foco en mantenimiento y evolución.',
};

const proofLabel = {
  pt: 'Em produção agora',
  en: 'Live right now',
  es: 'En producción ahora',
};

const availableLabel = {
  pt: 'Aberto para freelance, consultoria ou CLT remoto',
  en: 'Open for freelance, consulting or remote positions',
  es: 'Disponible para freelance, consultoría o empleo remoto',
};

const liveProjectDescriptions: Record<string, Record<string, string>> = {
  SistemaZapChat: { pt: 'Plataforma de bots WhatsApp com IA', en: 'AI-powered WhatsApp bot platform', es: 'Plataforma de bots WhatsApp con IA' },
  SmartVoz: { pt: 'Sistema de discagem VoIP automática', en: 'Automatic VoIP dialing system', es: 'Sistema de marcación VoIP automática' },
  'DesafiosBíblicos': { pt: 'App de quiz bíblico gamificado', en: 'Gamified Bible quiz app', es: 'App de quiz bíblico gamificado' },
};
---

<section
  class="relative px-6 max-w-6xl mx-auto py-20 lg:py-28"
  aria-label="Hero"
>
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 lg:gap-16 items-center">
    <!-- Left: Content -->
    <div class="flex flex-col gap-6">
      <!-- Name -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-text-primary leading-tight">
        Victor Bertram
      </h1>

      <!-- Role -->
      <p class="text-sm font-mono text-accent tracking-wide -mt-3">Senior Full Stack Developer</p>

      <!-- Headline -->
      <p class="text-base sm:text-lg text-text-secondary leading-relaxed max-w-xl">
        {headline[lang]}
      </p>

      <!-- Tech badges -->
      <div class="flex flex-wrap gap-2">
        {topTechs.map((tech) => (
          <span class="px-3 py-1 text-xs font-mono text-text-secondary bg-navy-dark border border-border rounded">
            {tech}
          </span>
        ))}
      </div>

      <!-- CTAs + Social -->
      <div class="flex items-center gap-4 flex-wrap mt-1">
        <a
          href={WA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-accent text-white font-semibold rounded-lg hover:bg-accent/90 transition-colors duration-200 cursor-pointer inline-flex items-center gap-2"
        >
          {lang === 'en' ? 'Schedule a call' : lang === 'es' ? 'Agendar llamada' : 'Agendar conversa'}
        </a>
        <a
          href={getLocalizedPath('/projects', lang)}
          class="px-6 py-3 border border-border text-text-primary font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200 cursor-pointer"
        >
          {t(lang, 'hero.cta_projects')}
        </a>

        <!-- Divider -->
        <span class="hidden sm:block w-px h-6 bg-border" aria-hidden="true"></span>

        <!-- Social inline -->
        <div class="flex items-center gap-3">
          <a href="https://github.com/VictorD19" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="w-9 h-9 rounded-lg border border-border flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent/40 transition-all duration-200 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
            </svg>
          </a>
          <a href="https://linkedin.com/in/victord08" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-lg border border-border flex items-center justify-center text-text-secondary hover:text-accent hover:border-accent/40 transition-all duration-200 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Photo -->
    <div class="flex flex-col items-center">
      <div class="relative">
        <div class="absolute -inset-1 bg-accent/10 rounded-2xl blur-lg" aria-hidden="true"></div>
        <div class="relative w-56 h-56 lg:w-72 lg:h-72 rounded-2xl overflow-hidden border-2 border-border shadow-lg">
          <img
            src="/images/victor-bertram.jpeg"
            alt="Victor Bertram - Senior Full Stack Developer"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Live projects bar -->
  <div class="flex items-center justify-center gap-3 mt-20 flex-wrap">
    <span class="text-[11px] font-mono text-text-secondary uppercase tracking-widest">{proofLabel[lang]}</span>
    <span class="w-px h-4 bg-border hidden sm:block" aria-hidden="true"></span>
    {liveProjects.map((project) => (
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-3 py-1.5 bg-navy-dark border border-border rounded-full text-sm font-medium text-text-primary hover:border-accent/40 hover:text-accent transition-all duration-200 cursor-pointer"
      >
        {project.icon === 'chat' && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        )}
        {project.icon === 'signal' && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/>
          </svg>
        )}
        {project.icon === 'trophy' && (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
          </svg>
        )}
        {project.name}
      </a>
    ))}
  </div>
</section>
