---
import BaseLayout from './BaseLayout.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { t } from '../i18n/config';
import { formatDate, getReadingTime } from '../lib/utils';
import type { Lang } from '../i18n/config';

interface TOCHeading {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedPost {
  slug: string;
  title: string;
  category: string;
  lang: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  category: string;
  image?: string;
  lang: Lang;
  headings?: TOCHeading[];
  rawContent?: string;
  relatedPosts?: RelatedPost[];
  slug: string;
}

const {
  title,
  description,
  date,
  tags,
  category,
  image,
  lang,
  headings = [],
  rawContent = '',
  relatedPosts = [],
  slug,
} = Astro.props;

const readingTime = getReadingTime(rawContent);
const formattedDate = formatDate(date, lang);
const pageUrl = Astro.url.href;

// Filter TOC to h2 and h3 only
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Victor Bertram',
    url: 'https://victorbertram.dev',
  },
  url: pageUrl,
  ...(image ? { image } : {}),
  keywords: tags.join(', '),
  inLanguage: lang,
});
---

<BaseLayout
  title={`${title} | Victor Bertram`}
  description={description}
  lang={lang}
  ogImage={image}
  type="article"
  publishedDate={date.toISOString()}
>
  <script type="application/ld+json" set:html={jsonLd} />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-text-secondary" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2">
        <li>
          <a href={lang === 'pt' ? '/' : `/${lang}`} class="hover:text-accent transition-colors">
            Home
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li>
          <a href={lang === 'pt' ? '/blog' : `/${lang}/blog`} class="hover:text-accent transition-colors">
            Blog
          </a>
        </li>
        <li aria-hidden="true" class="text-border">/</li>
        <li class="text-text-primary truncate max-w-[200px]" aria-current="page">{title}</li>
      </ol>
    </nav>

    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Sidebar TOC -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block lg:w-64 flex-shrink-0">
          <div class="sticky top-24">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-text-secondary mb-4">
              {t(lang, 'blog_page.toc') || 'Contents'}
            </h2>
            <nav aria-label="Table of contents">
              <ul class="space-y-2">
                {tocHeadings.map((heading) => (
                  <li class={heading.depth === 3 ? 'pl-4' : ''}>
                    <a
                      href={`#${heading.slug}`}
                      class="block text-sm text-text-secondary hover:text-accent transition-colors duration-200 py-0.5 leading-snug"
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Main Article -->
      <article class="flex-1 min-w-0">
        <!-- Metadata header -->
        <header class="mb-10">
          <div class="flex items-center gap-3 mb-4 flex-wrap">
            <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent bg-accent/10 rounded-full border border-accent/20">
              {category}
            </span>
            <span class="text-text-secondary text-sm">{formattedDate}</span>
            <span class="text-text-secondary text-sm flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              {readingTime} {t(lang, 'blog_page.min_read')}
            </span>
          </div>

          <h1 class="text-3xl md:text-4xl font-extrabold text-text-primary leading-tight mb-4">
            {title}
          </h1>

          <p class="text-lg text-text-secondary leading-relaxed mb-6">
            {description}
          </p>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="inline-block px-2.5 py-1 text-xs font-mono text-text-secondary bg-navy-light rounded border border-border">
                #{tag}
              </span>
            ))}
          </div>
        </header>

        <!-- Article content -->
        <div class="prose prose-lg max-w-none
          prose-headings:text-text-primary prose-headings:font-bold
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-text-secondary prose-p:leading-relaxed
          prose-a:text-accent prose-a:no-underline hover:prose-a:underline
          prose-strong:text-text-primary
          prose-code:text-accent prose-code:bg-navy-light prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none
          prose-pre:bg-navy-light prose-pre:border prose-pre:border-border prose-pre:rounded-xl
          prose-blockquote:border-l-accent prose-blockquote:text-text-secondary
          prose-ul:text-text-secondary prose-ol:text-text-secondary
          prose-li:marker:text-accent
          prose-hr:border-border
          prose-img:rounded-xl prose-img:border prose-img:border-border">
          <slot />
        </div>

        <!-- Footer: Share + Related -->
        <footer class="mt-16 pt-8 border-t border-border">
          <!-- Share buttons -->
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-12">
            <ShareButtons title={title} url={pageUrl} />
            <a
              href={lang === 'pt' ? '/blog' : `/${lang}/blog`}
              class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
              </svg>
              {t(lang, 'sections.view_all_posts')}
            </a>
          </div>

          <!-- Related posts -->
          {relatedPosts.length > 0 && (
            <div>
              <h2 class="text-xl font-bold text-text-primary mb-6">
                {t(lang, 'blog_page.related') || 'Related posts'}
              </h2>
              <div class="grid sm:grid-cols-2 gap-4">
                {relatedPosts.map((post) => {
                  const postHref = post.lang === 'pt' ? `/blog/${post.slug}` : `/${post.lang}/blog/${post.slug}`;
                  return (
                    <a
                      href={postHref}
                      class="block p-4 rounded-xl bg-navy-light border border-border hover:border-accent/40 transition-colors duration-200 group"
                    >
                      <span class="text-xs text-accent font-semibold uppercase tracking-wider">{post.category}</span>
                      <p class="mt-1 text-text-primary font-medium group-hover:text-accent transition-colors duration-200 line-clamp-2">
                        {post.title}
                      </p>
                    </a>
                  );
                })}
              </div>
            </div>
          )}
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>
