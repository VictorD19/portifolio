---
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  // In Astro 5 glob loader, 'cve-2025-29927.pt.mdx' -> id 'cve-2025-29927pt'
  // (github-slugger removes dots). Strip trailing lang code for clean URL slugs.
  const posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'pt' && !data.draft;
  });

  return posts.map((post) => ({
    params: { slug: post.id.replace(/(pt|en|es)$/, '') },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === 'pt' && !data.draft;
});

const currentSlug = post.id.replace(/(pt|en|es)$/, '');

const relatedPosts = allPosts
  .filter((p) => p.id.replace(/(pt|en|es)$/, '') !== currentSlug && p.data.category === post.data.category)
  .slice(0, 2)
  .map((p) => ({
    slug: p.id.replace(/(pt|en|es)$/, ''),
    title: p.data.title,
    category: p.data.category,
    lang: 'pt' as const,
  }));
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  tags={post.data.tags}
  category={post.data.category}
  image={post.data.image}
  lang="pt"
  headings={headings}
  rawContent={post.body ?? ''}
  relatedPosts={relatedPosts}
  slug={currentSlug}
>
  <Content />
</BlogPostLayout>
