---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';
import { getLangFromUrl, t } from '../i18n/config';

const lang = getLangFromUrl(Astro.url);
const title = `Victor Bertram – ${t(lang, 'contact.title')}`;
const description = t(lang, 'contact.title');

const labels = {
  name: t(lang, 'contact.name'),
  email: t(lang, 'contact.email'),
  subject: t(lang, 'contact.subject'),
  message: t(lang, 'contact.message'),
  send: t(lang, 'contact.send'),
  name_required: t(lang, 'contact.name_required'),
  email_invalid: t(lang, 'contact.email_invalid'),
  message_required: t(lang, 'contact.message_required'),
};

const waText = encodeURIComponent('Olá Victor! Gostaria de conversar sobre um projeto.');
---

<BaseLayout title={title} description={description} lang={lang}>
  <section class="max-w-5xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-extrabold text-text-primary mb-2">{t(lang, 'contact.title')}</h1>
    <p class="text-text-secondary mb-10 text-sm font-mono">
      <span class="text-accent">~/</span>{t(lang, 'contact.title').toLowerCase()}
    </p>

    <div class="lg:flex lg:gap-12">
      <!-- Left: Contact Form -->
      <div class="lg:flex-1">
        <ContactForm client:load labels={labels} />
      </div>

      <!-- Right: Side panel -->
      <aside class="mt-10 lg:mt-0 lg:w-72 flex flex-col gap-6">
        <!-- WhatsApp -->
        <a
          href={`https://wa.me/5549998218294?text=${waText}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-10 h-10 rounded bg-[var(--color-navy-light)] border border-[var(--color-border)] flex items-center justify-center flex-shrink-0 group-hover:border-[var(--color-accent)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-accent">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </span>
          <span class="text-sm font-medium">WhatsApp</span>
        </a>

        <!-- Email -->
        <a
          href="mailto:victor@email.com"
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-10 h-10 rounded bg-[var(--color-navy-light)] border border-[var(--color-border)] flex items-center justify-center flex-shrink-0 group-hover:border-[var(--color-accent)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <span class="text-sm font-medium">victor@email.com</span>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/victorbertram"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-10 h-10 rounded bg-[var(--color-navy-light)] border border-[var(--color-border)] flex items-center justify-center flex-shrink-0 group-hover:border-[var(--color-accent)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-accent">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </span>
          <span class="text-sm font-medium">LinkedIn</span>
        </a>

        <!-- Location -->
        <div class="flex items-center gap-3 text-text-secondary">
          <span class="w-10 h-10 rounded bg-[var(--color-navy-light)] border border-[var(--color-border)] flex items-center justify-center flex-shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <span class="text-sm font-medium">Chapecó, SC - Brasil</span>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
