---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import ScrollAnimation from '../../../components/ScrollAnimation.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/config';
import { getReadingTime } from '../../../lib/utils';

const lang = 'en';

function idToSlug(id: string): string {
  return id.replace(/(pt|en|es)$/, '');
}

let posts = await getCollection('blog', ({ data }) => {
  return data.lang === 'en' && !data.draft;
});

const useFallback = posts.length === 0;
if (useFallback) {
  posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'pt' && !data.draft;
  });
}

posts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title={`Blog | Victor Bertram`}
  description={t(lang, 'blog_page.title')}
  lang={lang}
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-20">
    <ScrollAnimation animation="slide-up">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text-primary mb-4">
        {t(lang, 'blog_page.title')}
      </h1>
      {useFallback && (
        <p class="text-sm text-yellow-400 mb-4">{t(lang, 'blog_page.fallback')}</p>
      )}
    </ScrollAnimation>

    <div id="search" class="mb-8"></div>
    <script>
      if (document.getElementById('search')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
          new (window as any).PagefindUI({
            element: '#search',
            showSubResults: false,
            showImages: false,
          });
        };
        document.head.appendChild(script);
      }
    </script>

    {posts.length === 0 ? (
      <ScrollAnimation animation="fade-in">
        <p class="text-text-secondary text-center py-20">{t(lang, 'blog_page.empty')}</p>
      </ScrollAnimation>
    ) : (
      <div class="flex flex-wrap gap-2">
        {posts.map((post, index) => {
          const postLang = post.data.lang;
          const slug = idToSlug(post.id);
          const readingTime = getReadingTime(post.body ?? '');
          return (
            <ScrollAnimation animation="slide-up" delay={index * 100} class="w-full sm:w-[calc(50%-4px)] lg:w-[calc(33.333%-6px)]">
              <BlogCard
                slug={slug}
                title={post.data.title}
                description={post.data.description}
                category={post.data.category}
                tags={post.data.tags}
                readingTime={readingTime}
                publishedDate={post.data.date}
                lang={postLang === 'en' ? 'en' : 'pt'}
              />
            </ScrollAnimation>
          );
        })}
      </div>
    )}
  </section>
</BaseLayout>
