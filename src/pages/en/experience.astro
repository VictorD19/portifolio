---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceTimeline from '../../components/ExperienceTimeline.tsx';
import ScrollAnimation from '../../components/ScrollAnimation.astro';
import { t } from '../../i18n/config';
import { getExperiencesByLang } from '../../data/experience';

const lang = 'en' as const;
const experiences = getExperiencesByLang(lang);

const title = 'Experience | Victor Bertram';
const description = 'My professional journey and education.';
---

<BaseLayout title={title} description={description} lang={lang}>
  <section class="max-w-6xl mx-auto px-6 py-20">
    <ScrollAnimation animation="slide-up">
      <div class="mb-16">
        <p class="text-accent font-mono text-sm mb-2">~/experience</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-text-primary mb-4">
          Experience
        </h1>
        <p class="text-text-secondary text-lg max-w-2xl">
          Every step of my journey prepared me for what I do today.
        </p>
      </div>
    </ScrollAnimation>

    <ExperienceTimeline
      client:load
      experiences={experiences}
      workLabel="Work"
      educationLabel="Education"
      lang={lang}
    />
  </section>
</BaseLayout>
