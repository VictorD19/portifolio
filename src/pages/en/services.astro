---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollAnimation from '../../components/ScrollAnimation.astro';
import { t } from '../../i18n/config';
import { getServicesByLang } from '../../data/services';

const lang = 'en' as const;
const services = getServicesByLang(lang);

const title = `${t(lang, 'services_page.title')} | Victor Bertram`;
const description = t(lang, 'footer.services');

const webMobile = services.filter((s) => ['web-development', 'mobile-development'].includes(s.slug));
const consultingAutomation = services.filter((s) => ['consulting', 'automations'].includes(s.slug));
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 flex flex-col gap-24">
    <!-- Header -->
    <ScrollAnimation animation="slide-up">
      <div>
        <p class="text-accent font-mono text-sm mb-2">~/services</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-text-primary mb-4">
          {t(lang, 'services_page.title')}
        </h1>
      </div>
    </ScrollAnimation>

    <!-- Section 1: Web & Mobile Development -->
    <section class="flex flex-col gap-10">
      <ScrollAnimation animation="slide-up">
        <div class="flex items-center gap-3 mb-2">
          <div class="h-px flex-1 bg-gradient-to-r from-accent/40 to-transparent"></div>
          <span class="text-accent font-mono text-xs uppercase tracking-widest">Development</span>
          <div class="h-px flex-1 bg-gradient-to-l from-accent/40 to-transparent"></div>
        </div>
        <p class="text-center text-text-secondary text-lg max-w-2xl mx-auto">
          From zero to deploy — I create and architect web and mobile systems tailored to your business.
        </p>
      </ScrollAnimation>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {webMobile.map((service, index) => (
          <ScrollAnimation animation="slide-up" delay={index * 100}>
            <div class="relative bg-navy-light border border-border rounded-2xl p-8 h-full hover:border-accent/40 transition-all duration-300">
              <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
              <div class="relative">
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-14 h-14 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      {service.icon === 'globe' && <><circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" /></>}
                      {service.icon === 'smartphone' && <><rect width="14" height="20" x="5" y="2" rx="2" ry="2" /><path d="M12 18h.01" /></>}
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-text-primary">{service.title}</h2>
                    <p class="text-text-secondary text-sm mt-1">{service.description}</p>
                  </div>
                </div>

                <ul class="flex flex-col gap-3 mb-8">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3 text-sm text-text-secondary">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>

                <a
                  href="/en/contact"
                  class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-accent rounded-lg hover:bg-accent/90 transition-colors duration-200"
                >
                  {t(lang, 'services_page.cta')}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </ScrollAnimation>
        ))}
      </div>
    </section>

    <!-- Section 2: Consulting & Automations -->
    <section class="flex flex-col gap-10">
      <ScrollAnimation animation="slide-up">
        <div class="flex items-center gap-3 mb-2">
          <div class="h-px flex-1 bg-gradient-to-r from-accent/40 to-transparent"></div>
          <span class="text-accent font-mono text-xs uppercase tracking-widest">Strategy & Optimization</span>
          <div class="h-px flex-1 bg-gradient-to-l from-accent/40 to-transparent"></div>
        </div>
        <p class="text-center text-text-secondary text-lg max-w-2xl mx-auto">
          I identify bottlenecks, eliminate manual processes, and put your team on the right track.
        </p>
      </ScrollAnimation>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {consultingAutomation.map((service, index) => (
          <ScrollAnimation animation="slide-up" delay={index * 100}>
            <div class="relative bg-navy-light border border-border rounded-2xl p-8 h-full hover:border-accent/40 transition-all duration-300">
              <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
              <div class="relative">
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-14 h-14 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      {service.icon === 'lightbulb' && <><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" /><path d="M9 18h6" /><path d="M10 22h4" /></>}
                      {service.icon === 'bot' && <><path d="M12 8V4H8" /><rect width="16" height="12" x="4" y="8" rx="2" /><path d="M2 14h2" /><path d="M20 14h2" /><path d="M15 13v2" /><path d="M9 13v2" /></>}
                    </svg>
                  </div>
                  <div>
                    <h2 class="text-2xl font-bold text-text-primary">{service.title}</h2>
                    <p class="text-text-secondary text-sm mt-1">{service.description}</p>
                  </div>
                </div>

                <ul class="flex flex-col gap-3 mb-8">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3 text-sm text-text-secondary">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>

                <a
                  href="/en/contact"
                  class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-accent rounded-lg hover:bg-accent/90 transition-colors duration-200"
                >
                  {t(lang, 'services_page.cta')}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </ScrollAnimation>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
